# ==========================================
# Fitly — Environment Variables Template
# Copy this to .env.local and fill in values
# ==========================================

# --- Supabase (DB + Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Database (Drizzle direct connection) ---
# Supabase "Connection pooling" — Transaction mode 권장 (port 6543).
# 세션 모드(5432)는 무료 티어에서 client 15 제한 → Next.js dev/serverless 환경에서
# EMAXCONNSESSION 에러가 발생할 수 있다. lib/db/index.ts 가 prepare:false 로
# 트랜잭션 풀러와 호환되도록 설정되어 있다.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- Google Gemini (메인 LLM + Vision OCR + 임베딩, 헌법 제18조 v1.5) ---
GEMINI_API_KEY=AIza...
# 2026-05-17 — 종전 example 은 두 슬롯 모두 gemini-3.1-pro-preview 였음. Flash
# 슬롯에 Pro Preview 가 박히면 (1) 채점·챗봇이 Flash 가정한 1~2s 가 아니라
# 5~10s 응답으로 Vercel 30s 한도 누적 부담, (2) preview 모델 rate limit 영향.
# 안정 세대(2.5)로 example 복구. 신모델 시험이 필요한 dev 만 명시 override.
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# --- App URL (PWA / OG / OAuth callback) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin 화이트리스트 (헌법 법률17 제28조) ---
# 콤마 구분 UUID 목록. 비어 있으면 누구도 admin 권한 미부여 (deny by default).
# `/admin/*` 라우트 + `lib/seed-review/actions.ts` 운영자 server action 가드에 사용.
ADMIN_USER_IDS=

# --- Optional: Posthog (분석) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Optional: Sentry (에러 트래킹) ---
SENTRY_DSN=
